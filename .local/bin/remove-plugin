#!/bin/bash
set -eu

if [ $# -ne 1 ]; then
  echo "usage: remove-plugin <name>" >&2
  exit 1
fi

name="$1"
path=".config/nvim/pack/vendor/start/$name"

config() { git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" "$@"; }

cd "$HOME"

if [ ! -d "$path" ]; then
  echo "error: $path does not exist" >&2
  echo "available plugins:" >&2
  ls .config/nvim/pack/vendor/start/ >&2
  exit 1
fi

config submodule deinit -f "$path"
config rm -f "$path"
rm -rf "$HOME/.dotfiles/modules/$path"

cfg=".config/nvim/lua/config/plugins/$name.lua"
if [ -f "$cfg" ]; then
  rm "$cfg"
  echo "Removed $cfg"
fi

echo
echo "Removed $name"
echo
echo "Next steps:"
echo "  1. remove require('config.plugins.$name') from .config/nvim/lua/config/plugins.lua (if present)"
echo "  2. config commit"
