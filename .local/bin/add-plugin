#!/bin/bash
set -eu

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
  echo "usage: add-plugin <author/repo> [sha]" >&2
  exit 1
fi

repo="$1"
sha="${2:-}"
name="${repo##*/}"
name="${name%.git}"
path=".config/nvim/pack/vendor/start/$name"

config() { git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" "$@"; }

cd "$HOME"

if [ -d "$path" ]; then
  echo "error: $path already exists" >&2
  exit 1
fi

config submodule add "git@github.com:${repo}.git" "$path"

if [ -n "$sha" ]; then
  git -C "$path" fetch --depth 1 origin "$sha"
  git -C "$path" checkout "$sha"
fi

echo
echo "Added $repo at ~/$path"
[ -f "$path/Makefile" ] && echo "  note: $path/Makefile detected — run make there if the plugin needs a build step"
echo
echo "Next steps:"
echo "  1. create .config/nvim/lua/config/plugins/$name.lua with your setup (skip for pure deps)"
echo "  2. add require('config.plugins.$name') to .config/nvim/lua/config/plugins.lua"
echo "  3. config commit"
