[diff]
	external = difft
	renames = true
	indentHeuristic = on
	algorithm = histogram

[core]
	pager = delta
	editor = nvim
	fsmonitor = true
	untrackedCache = true
	commitGraph = true

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	followTags = true

[pull]
	rebase = true

[fetch]
	prune = true
	writeCommitGraph = true

[gc]
	writeCommitGraph = true

[merge]
	conflictstyle = zdiff3

[rebase]
	autosquash = true
	autostash = true

[rerere]
	enabled = true

[color]
	ui = auto

[delta]
	plus-style = syntax "#012800"
	minus-style = normal "#340001"
	syntax-theme = Monokai Extended

[interactive]
	diffFilter = delta --color-only

[alias]
	st = status
	br = branch
	f = fetch
	cma = commit -a -m
	co = checkout
	l = "log -i -n 10 --format='%C(auto) %>(12,trunc)%aL | %h %s' --abbrev-commit --no-merges"

# Bare-repo safety net: any time git operates on ~/.dotfiles, force fsmonitor
# and untrackedCache off so we don't index all of $HOME. Defense in depth —
# the bootstrap also sets these locally on the bare repo.
[includeIf "gitdir:~/.dotfiles"]
	path = ~/.config/git/dotfiles-bare

# Machine-local overrides (not tracked). Must be last so it wins.
# This is also where per-machine includeIfs live (e.g. work gitconfig).
[include]
	path = ~/.gitconfig.local
